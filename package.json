{
  "name": "@erwisnu/opencode-kiro-auth",
  "version": "0.1.3",
  "description": "OpenCode plugin for Kiro authentication, multi-account rotation, and quota tracking.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/provider/transport.d.ts",
      "import": "./dist/provider/transport.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:js": "bun build ./src/index.ts ./src/provider/transport.ts --outdir ./dist --target bun",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "check": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.21",
    "@opencode-ai/sdk": "1.2.21",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/node": "^22.13.9",
    "typescript": "^5.9.2"
  }
}
